generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  salt         String
  name         String
  role         String   @default("user")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  licenses     License[]
  activityLogs ActivityLog[]
  vehicles     Vehicle[]
  sessions     DiagnosticSession[]
}

model License {
  id          String   @id @default(cuid())
  userId      String
  licenseKey  String   @unique
  hwid        String?
  licenseType String   @default("trial")
  status      String   @default("active")
  expiresAt   DateTime
  maxDevices  Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  ip        String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Vehicle {
  id            String   @id @default(cuid())
  userId        String
  vin           String   @unique
  brand         String   @default("Mercedes-Benz")
  model         String?
  year          Int?
  engine        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
  sessions      DiagnosticSession[]
}

model DiagnosticSession {
  id            String       @id @default(cuid())
  userId        String
  vehicleId     String?
  status        String       @default("active")
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  user          User         @relation(fields: [userId], references: [id])
  vehicle       Vehicle?     @relation(fields: [vehicleId], references: [id])
  faultCodes    FaultCode[]
  testResults   TestResult[]
  reports       DiagnosisReport[]
}

model FaultCode {
  id         String   @id @default(cuid())
  sessionId  String
  code       String
  description String?
  severity   String   @default("info")
  status     String   @default("active")
  createdAt  DateTime @default(now())
  session    DiagnosticSession @relation(fields: [sessionId], references: [id])
}

model TestResult {
  id         String   @id @default(cuid())
  sessionId  String
  testName   String
  result     String
  unit       String?
  value      String?
  min        String?
  max        String?
  status     String   @default("passed")
  createdAt  DateTime @default(now())
  session    DiagnosticSession @relation(fields: [sessionId], references: [id])
}

model DiagnosisReport {
  id        String   @id @default(cuid())
  sessionId String
  title     String
  summary   String?
  content   String?
  createdAt DateTime @default(now())
  session   DiagnosticSession @relation(fields: [sessionId], references: [id])
}
